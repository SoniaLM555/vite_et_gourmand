{% extends 'base.html.twig' %}

{% block title %}Nouveau régime{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Ajouter un nouveau régime</h1>
    <a href="{{ path('app_regime_index') }}" class="btn btn-secondary">Retour à la liste</a>
</div>

<div class="card p-4 shadow-sm mb-4">
    {{ include('regime/_form.html.twig') }}
</div>

<div class="d-flex justify-content-start mt-3">
    <button type="submit" form="form-regime" class="btn btn-secondary">Enregistrer le régime</button>
</div>

{% endblock %}
