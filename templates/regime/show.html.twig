{% extends 'base.html.twig' %}

{% block title %}Détails du régime{% endblock %}

{% block body %}
    <h1>Régime : {{ regime.nom }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ regime.id }}</td>
            </tr>
            <tr>
                <th>Nom du régime</th>
                <td>{{ regime.nom }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_regime_index') }}">Retour à la liste</a>

    <a href="{{ path('app_regime_edit', {'id': regime.id}) }}">Modifier</a>

    {{ include('regime/_delete_form.html.twig') }}
{% endblock %}
