{% extends 'base.html.twig' %}

{% block title %}Détails du rôle{% endblock %}

{% block body %}
    <h1 class="mb-4">Rôle : {{ role.libelle }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ role.id }}</td>
            </tr>
            <tr>
                <th>Libellé</th>
                <td>{{ role.libelle }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_role_index') }}">Retour à la liste</a>

    <a href="{{ path('app_role_edit', {'id': role.id}) }}">Modifier</a>

    {{ include('role/_delete_form.html.twig') }}
{% endblock %}
