{% extends 'base.html.twig' %}

{% block title %}Accueil - Vite & Gourmand {% endblock %}

{% block body %}


<section class="hero-section d-flex align-items-center justify-content-center text-center text-white" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{ asset('images/plat_gastronomie_hero_accueil.jpg') }}'); background-size: cover;background-position: center; min-height: 60vh;">
    <div class="container">
        <h1 class="display-4 mb-5" style="font-family: 'Playfair Display', serif;">L'excellence gastronomique à votre table</h1>
        <p class="lead mb-5 mx-auto" style="max-width: 950px;">Découvrez une expérience culinaire sur-mesure où le raffinement de la haute gastronomie s'invite chez vous pour transformer chaque événement en un instant inoubliable.</p>
        <a href="{{ path('app_menu_index') }}" class="btn btn-lg px-5" style="background-color: #000000 !important; border: 2px solid #000000 !important; color: #ffffff !important; " onmouseover="this.style.backgroundColor='#333333'; this.style.borderColor='#333333';" onmouseout="this.style.backgroundColor='#000000'; this.style.borderColor='#000000';">Découvrir les menus</a>
    </div>
</section>


<section class="py-5 container">
    <div class="row align-items-center py-5">
        <div class="col-md-6">
            <img src="{{ asset('images/restaurant_gastronimique_presentation.jpg') }}" class="img-fluid" alt="Qui sommes-nous" style="height: 500px; width: 100%; object-fit: cover;">
        </div>
        <div class="col-md-6 ps-md-5">
            <h2 class="display-6 mb-4" style="font-family: 'Playfair Display', serif;">Qui sommes-nous?</h2>
            <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
        </div>
    </div>
</section>


<section class="py-5 bg-light">
    <div class="container py-5">
        <h2 class="display-6 text-center mb-5" style="font-family: 'Playfair Display', serif;">Nos menus premiums</h2>
        <div class="row row-cols-1 row-cols-md-4 g-3">
            {% for menu in menus %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-0">
                    <img src="{{ asset('images/' ~ (menu.imageName ?? 'default.jpg')) }}" class="card-img-top rounded-0" alt="{{ menu.titre }}" style="height: 200px; width: 100%; object-fit: cover;">
                    <div class="card-body text-center">
                        <h5 class="card-title">{{ menu.titre }}</h5>
                        <p class="fw-bold">{{ menu.prixParPersonne }} €</p>
                        <p class="small text-muted mb-2">
                            Minimum {{ menu.nombrePersonneMin }} personnes.
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end pb-3">
                        <a href="{{ path('app_menu_show', {'id': menu.id}) }}" class="btn btn-outline-dark btn-sm">Détails</a>
                    </div>
                </div>
            </div>
            {% else %}
                <p class="text-center w-100">Aucun menu disponible pour le moment.</p>
            {% endfor %}
        </div>
        <div class="text-center mt-5">
            <a href="{{ path('app_menu_index') }}" class="btn btn-dark">Voir tous les menus</a>
        </div>
    </div>
</section>


<section class="py-5 container">
    <h2 class="display-6 text-center mb-5" style="font-family: 'Playfair Display', serif;">L'avis de nos clients</h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        {% for avis in ['Richard', 'Emeline', 'Sofia'] %}
        <div class="col">
            <div class="card p-4 border-0 bg-light text-center h-100">
                {# Affichage des 5 étoiles #}
                <div class="text-warning mb-3">
                    {% for i in 1..5 %}
                        <i class="bi bi-star-fill"></i>
                    {% endfor %}
                </div>
                <p class="fst-italic">"Lorem ipsum dolor sit amet, consectetur adipiscing elit."</p>
                <h6 class="mt-3 fw-bold">{{ avis }}</h6>
            </div>
        </div>
        {% endfor %}
    </div>
</section>

{% endblock %}
