{% extends 'base.html.twig' %}

{% block title %}Accueil - Vite & Gourmand {% endblock %}

{% block body %}


<section class="hero-section d-flex align-items-center justify-content-center text-center text-white" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{ asset('images/plat_gastronomie_hero_accueil.jpg') }}'); background-size: cover;background-position: center; min-height: 60vh;">
    <div class="container">
        <h1 class="display-4 mb-5" style="font-family: 'Playfair Display', serif;">L'excellence gastronomique à votre table</h1>
        <p class="lead mb-5 mx-auto" style="max-width: 950px;">Découvrez une expérience culinaire sur-mesure où le raffinement de la haute gastronomie s'invite chez vous pour transformer chaque événement en un instant inoubliable.</p>
        <a href="{{ path('app_menu_index') }}" class="btn btn-lg px-5" style="background-color: #000000 !important; border: 2px solid #000000 !important; color: #ffffff !important; " onmouseover="this.style.backgroundColor='#333333'; this.style.borderColor='#333333';" onmouseout="this.style.backgroundColor='#000000'; this.style.borderColor='#000000';">Découvrir les menus</a>
    </div>
</section>


<section class="py-5 container">
    <div class="row align-items-center py-5">
        <div class="col-md-6">
            <img src="{{ asset('images/restaurant_gastronimique_presentation.jpg') }}" class="img-fluid" alt="Photo de la salle du restaurant gastronomique de Julie et José" style="height: 500px; width: 100%; object-fit: cover;">
        </div>
        <div class="col-md-6 ps-md-5">
            <h2 class="display-6 mb-4" style="font-family: 'Playfair Display', serif;">Qui sommes-nous?</h2>
            <p class="text-muted">Installés au cœur de Bordeaux depuis 25 ans, nous sommes un duo passionné de gastronomie, animé par une mission simple : sublimer tous vos événements. Que ce soit pour partager un moment chaleureux lors d'un repas de Noël, célébrer les fêtes de Pâques en famille, ou organiser tout autre rassemblement marquant, Julie et José mettent leur savoir-faire unique au service de vos tables.
            </p>
            <p class="text-muted">Notre secret ? Un concept en constante évolution et des menus qui se renouvellent sans cesse pour s'adapter au fil des saisons et de vos envies. Historiquement partagée par e-mail avec notre cercle d'habitués, notre cuisine s'ouvre aujourd'hui à vous à travers cette vitrine numérique pour vous proposer l'art de la bonne table, en toute simplicité.
            </p>        
        </div>
    </div>
</section>


<section class="py-5 bg-light">
    <div class="container py-5">
        <h2 class="display-6 text-center mb-5" style="font-family: 'Playfair Display', serif;">Nos menus premiums</h2>
        <div class="row row-cols-1 row-cols-md-4 g-3">
            {% for menu in menus %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-0">
                    <img src="{{ asset('images/' ~ (menu.imageName ?? 'default.jpg')) }}" class="card-img-top rounded-0" alt="Photo d'illustration du menu premium :{{ menu.titre }}" style="height: 200px; width: 100%; object-fit: cover;">
                    <div class="card-body text-center">
                        <h3 class="card-title h5">{{ menu.titre }}</h3>
                        <p class="fw-bold">{{ menu.prixParPersonne }} €</p>
                        <p class="small .text-secondary mb-2">
                            Minimum {{ menu.nombrePersonneMin }} personnes.
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end pb-3">
                        <a href="{{ path('app_menu_show', {'id': menu.id}) }}" class="btn btn-outline-dark btn-sm">Détails</a>
                    </div>
                </div>
            </div>
            {% else %}
                <p class="text-center w-100">Aucun menu disponible pour le moment.</p>
            {% endfor %}
        </div>
        <div class="text-center mt-5">
            <a href="{{ path('app_menu_index') }}" class="btn btn-dark">Voir tous les menus</a>
        </div>
    </div>
</section>



{% if avis is not empty %}
    <div class="container my-5 py-4 bg-light rounded shadow-sm text-center">
        <h2 class="h4 fw-bold text-dark mb-4">Ce que nos clients disent de nous</h2>
        
        <div id="carouselAvis" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                {% for avi in avis %}
                    <div class="carousel-item {% if loop.first %}active{% endif %}" data-bs-interval="5000">
                        <div class="row justify-content-center">
                            <div class="col-md-8">
                                <div class="p-3">
                                   <div class="text-warning fs-5 mb-2">
                                        {% for i in 1..avi.note %}★{% endfor %}
                                    </div>
                                    <p class="fs-5 text-dark fst-italic">"{{ avi.commentaire }}"</p>
                                    <small class="text-dark fw-bold">
                                        Par {{ avi.utilisateur.prenom }} {{ avi.utilisateur.nom|slice(0, 1) }}. - le {{ avi.datePublication|date('d/m/Y') }}
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselAvis" data-bs-slide="prev" aria-label="Avis précédent">
                <span class="carousel-control-prev-icon bg-dark rounded-circle" aria-hidden="true"></span>
                <span class="visually-hidden">Précédent</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselAvis" data-bs-slide="next" aria-label="Avis suivant">
                <span class="carousel-control-next-icon bg-dark rounded-circle" aria-hidden="true"></span>
                <span class="visually-hidden">Suivant</span>
            </button>
        </div>
    </div>
{% endif %}


{% endblock %}
