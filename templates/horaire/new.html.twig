{% extends 'base.html.twig' %}

{% block title %}Nouvel horaire{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Ajouter un nouvel horaire</h1>
        <a href="{{ path('app_horaire_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <div class="card p-4 shadow-sm mb-4">
        {{ include('horaire/_form.html.twig') }}
    </div>

    <div class="d-flex justify-content-start mt-3">
        <button type="submit" form="form-horaire" class="btn btn-secondary">Enregistrer l'horaire</button>
    </div>

{% endblock %}
