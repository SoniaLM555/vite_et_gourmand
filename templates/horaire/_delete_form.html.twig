<form method="post" action="{{ path('app_horaire_delete', {'id': horaire.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cet horaire ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ horaire.id) }}">
    <button class="btn btn-sm btn-outline-secondary">Supprimer l'horaire</button>
</form>
