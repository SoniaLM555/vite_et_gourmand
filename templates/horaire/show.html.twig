{% extends 'base.html.twig' %}

{% block title %}Détails de l'horaire{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Détails de l'horaire : {{ horaire.jour }}</h1>
        <a href="{{ path('app_horaire_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Jour</th>
                <th>Ouverture</th>
                <th>Fermeture</th>
                <th>Actions</th>
            </tr>
        </thead>
        
        <tbody>
            <tr>
                <td>{{ horaire.id }}</td>
                <td><strong>{{ horaire.jour }}</strong></td>
                <td>{{ horaire.heureOuverture }}</td>
                <td>{{ horaire.heureFermeture }}</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_horaire_edit', {'id': horaire.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    
{% endblock %}