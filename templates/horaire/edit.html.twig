{% extends 'base.html.twig' %}

{% block title %}Modifier les horaires d'ouverture{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modifier les horaires d'ouverture</h1>
        <a href="{{ path('app_horaire_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <div class="card p-4 shadow-sm mb-4">
        {{ include('horaire/_form.html.twig') }}
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button type="submit" form="form-horaire" class="btn btn-secondary">Mettre à jour</button>
    </div>  
    
{% endblock %}
