{% extends 'base.html.twig' %}

{% block title %}Détails du plat{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Détails du plat : {{ plat.nom }}</h1>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Image</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        
        <tbody>
            <tr>
                <td>{{ plat.id }}</td>
                <td>{{ plat.nom }}</td>
                <td>
                    {% if plat.image %}
                        <img src="{{ asset('uploads/' ~ plat.image) }}" alt="{{ plat.nom }}" style="width: 100px; height: auto; border-radius: 5px;">
                    {% else %}
                        <span class="text-muted">Pas d'image</span>
                    {% endif %}
                </td>
                <td>{{ plat.description }}</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_plat_edit', {'id': plat.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        {{ include('plat/_delete_form.html.twig') }}
                    </div>
                </td>
            </tr>
        </tbody>
    </table>

    <div class="mt-4">
        <a href="{{ path('app_plat_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
{% endblock %}