{% extends 'base.html.twig' %}

{% block title %}Détails du plat{% endblock %}

{% block body %}
    <h1>Détails du plat : {{ plat.nom }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ plat.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ plat.nom }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{ plat.image }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ plat.description }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_plat_index') }}">Retour à la liste</a>

    <a href="{{ path('app_plat_edit', {'id': plat.id}) }}">Modifier</a>

    {{ include('plat/_delete_form.html.twig') }}
{% endblock %}
