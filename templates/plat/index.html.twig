{% extends 'base.html.twig' %}

{% block title %}Plat index{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des plats</h1>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Image</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for plat in plats %}
            <tr>
                <td>{{ plat.id }}</td>
                <td>{{ plat.nom }}</td>
                <td>
                    {% if plat.image %}
                        <img src="{{ asset('uploads/' ~ plat.image) }}" alt="{{ plat.nom }}" style="width: 100px; height: auto; border-radius: 5px;">
                    {% else %}
                        <span>Pas d'image</span>
                    {% endif %}
                </td>
                <td>{{ plat.description }}</td>
                <td>
                    <a href="{{ path('app_plat_show', {'id': plat.id}) }} " class="btn btn-sm btn-outline-secondary">Voir</a>
                    <a href="{{ path('app_plat_edit', {'id': plat.id}) }} " class="btn btn-sm btn-outline-secondary">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun résultat trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_plat_new') }}" class="btn btn-sm btn-secondary">Ajouter un plat</a>

{% endblock %}
