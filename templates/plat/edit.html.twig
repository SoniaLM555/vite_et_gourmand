{% extends 'base.html.twig' %}

{% block title %}Modifier le plat{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modifier le plat : {{ plat.nom }}</h1>
        <a href="{{ path('app_plat_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <div class="card p-4 shadow-sm mb-4">
        {{ include('plat/_form.html.twig') }}
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button type="submit" form="form-plat" class="btn btn-secondary">Mettre à jour</button>
     
        {{ include('plat/_delete_form.html.twig') }}
    </div>
{% endblock %}
