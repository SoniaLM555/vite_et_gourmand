{% extends 'base.html.twig' %}

{% block title %}Utilisateur index{% endblock %}

{% block body %}

    <div class="card p-4 shadow-sm mb-4 bg-white border-0 rounded">
        <h5 class="mb-3 text-secondary">Filtres d'analyse (SQL & MongoDB)</h5>
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label for="date_debut" class="form-label small text-muted">Date de début</label>
                <input type="date" id="date_debut" name="date_debut" class="form-control" value="{{ app.request.query.get('date_debut') }}">
            </div>
            <div class="col-md-3">
                <label for="date_fin" class="form-label small text-muted">Date de fin</label>
                <input type="date" id="date_fin" name="date_fin" class="form-control" value="{{ app.request.query.get('date_fin') }}">
            </div>
            <div class="col-md-4">
                <label for="menu_filtre" class="form-label small text-muted">Filtrer par nom de Menu</label>
                <input type="text" id="menu_filtre" name="menu_filtre" class="form-control" placeholder="Ex: Menu Gourmet" value="{{ app.request.query.get('menu_filtre') }}">
            </div>
            <div class="col-md-2 align-self-end">
                <button type="submit" class="btn btn-dark w-100">Appliquer</button>
            </div>
        </form>
    </div>

    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <div class="card p-3 shadow-sm border-0 bg-white h-100">
                <h5 class="text-center text-secondary mb-3">Chiffre d'Affaires par Menu (SQL SUM)</h5>
                <canvas id="chartSQL" style="max-height: 260px;"></canvas>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card p-3 shadow-sm border-0 bg-white h-100">
                <h5 class="text-center text-secondary mb-3">Volume de Commandes par Menu (NoSQL MongoDB)</h5>
                <canvas id="chartNoSQL" style="max-height: 260px;"></canvas>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des utilisateurs</h1>
        <a href="{{ path('app_utilisateur_new') }}" class="btn btn-sm btn-secondary">Ajouter un utilisateur</a>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Email</th>
                    <th>Nom et prénom</th>
                    <th>Ville</th>
                    <th>Rôle</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for utilisateur in utilisateurs %}
                    <tr>
                        <td>{{ utilisateur.id }}</td>
                        <td>{{ utilisateur.email }}</td>
                        <td>{{ utilisateur.nom|upper }} {{ utilisateur.prenom }}</td>
                        <td>{{ utilisateur.ville|default('Non renseignée') }}</td>
                        <td>
                            {% if utilisateur.roleObjet %}
                                {% set libelle = utilisateur.roleObjet.libelle %}
                                {% if libelle == 'Administrateur' %}
                                    <span class="badge bg-danger small">Administrateur</span>
                                {% elseif libelle == 'Employé' %}
                                    <span class="badge bg-warning text-dark small">Employé</span>
                                {% else %}
                                    <span class="badge bg-secondary small">{{ libelle }}</span>
                                {% endif %}
                            {% else %}
                                <span class="badge bg-secondary small">Client</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if utilisateur.isVerified %}
                                <span class="badge bg-success">Actif</span>
                            {% else %}
                                <span class="badge bg-warning text-dark">En attente</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_utilisateur_show', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                                <form method="post" action="{{ path('app_utilisateur_toggle', {'id': utilisateur.id}) }}" onsubmit="return confirm('Changer le statut de cet utilisateur ?');" style="display:inline;">
                                    <button class="btn btn-sm {{ utilisateur.isVerified ? 'btn-outline-danger' : 'btn-outline-success' }}">
                                        {{ utilisateur.isVerified ? 'Désactiver' : 'Activer' }}
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center">Aucun résultat trouvé</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labelsSQL = [{% for ca in totalChiffreAffaires|default([]) %}"{{ ca.menu_nom }}",{% endfor %}];
        const dataSQL = [{% for ca in totalChiffreAffaires|default([]) %}{{ ca.chiffre_affaires }},{% endfor %}];

        const labelsNoSQL = [{% for stat in statsNoSQL|default([]) %}"{{ stat.menu }}",{% endfor %}];
        const dataNoSQL = [{% for stat in statsNoSQL|default([]) %}{{ stat.volume }},{% endfor %}];

        new Chart(document.getElementById('chartSQL'), {
            type: 'bar',
            data: {
                labels: labelsSQL.length ? labelsSQL : ["Aucun retour"],
                datasets: [{
                    label: "CA Global (€)",
                    data: dataSQL.length ? dataSQL : [0],
                    backgroundColor: '#4b5563',
                    borderRadius: 4
                }]
            },
            options: { responsive: true }
        });

        new Chart(document.getElementById('chartNoSQL'), {
            type: 'doughnut',
            data: {
                labels: labelsNoSQL.length ? labelsNoSQL : ["Aucun volume"],
                datasets: [{
                    data: dataNoSQL.length ? dataNoSQL : [1],
                    backgroundColor: ['#10b981', '#f59e0b', '#ef4444', '#06b6d4']
                }]
            },
            options: { responsive: true }
        });
    </script>
{% endblock %}