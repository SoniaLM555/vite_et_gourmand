{% extends 'base.html.twig' %}

{% block title %}Détails de l'utilisateur{% endblock %}

{% block body %}

<div class="container py-4 text-charte-dark">

    {% if is_granted('ROLE_ADMIN') and app.user != utilisateur %}

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Détails de l'utilisateur : {{ utilisateur.prenom }} {{ utilisateur.nom }}</h1>
            <a href="{{ path('app_utilisateur_index') }}" class="btn btn-secondary">Retour à la liste</a>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Email</th>
                    <th>Nom et prénom</th>
                    {% if utilisateur.roleObjet and utilisateur.roleObjet.libelle != 'Employé' %}
                        <th>Adresse</th>
                        <th>Ville</th>
                    {% endif %}
                    <th>Rôle</th>
                    {% if utilisateur.roleObjet and utilisateur.roleObjet.libelle != 'Employé' %}
                        <th>Vérifié</th>
                    {% endif %}
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>{{ utilisateur.id }}</td>
                    <td>{{ utilisateur.email }}</td>
                    <td>{{ utilisateur.nom|upper }} {{ utilisateur.prenom }}</td>
                    
                    {% if utilisateur.roleObjet and utilisateur.roleObjet.libelle != 'Employé' %}
                        <td>{{ utilisateur.adressePostale|default('Non renseignée') }}</td>
                        <td>{{ utilisateur.ville|default('Non renseignée') }}</td>
                    {% endif %}
                    
                    <td>{{ utilisateur.roleObjet ? utilisateur.roleObjet.libelle : 'Client' }}</td>
                    
                    {% if utilisateur.roleObjet and utilisateur.roleObjet.libelle != 'Employé' %}
                        <td>
                            {% if utilisateur.isVerified %}
                                <span class="badge bg-success">Compte confirmé</span>
                            {% else %}
                                <span class="badge bg-danger">Email non vérifié</span>
                            {% endif %}
                        </td>
                    {% endif %}
                    
                    <td>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                            
                            {# Remplacement du formulaire de suppression par le bouton désactiver #}
                            <form method="post" action="{{ path('app_utilisateur_toggle', {'id': utilisateur.id}) }}" onsubmit="return confirm('Confirmer le changement de statut ?');">
                                <button class="btn btn-sm btn-outline-danger">
                                    {{ utilisateur.isVerified ? 'Désactiver' : 'Réactiver' }}
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>

    {% else %}
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Mon espace personnel (Staff)</h1>
            <a href="{{ path('app_menu_index') }}" class="btn btn-outline-dark">Retour aux menus</a>
        </div>

        <div class="card p-4 shadow-sm mb-5 bg-white border-0 rounded">
            <h3 class="h5 mb-4 text-secondary border-bottom pb-2">Mes Informations Professionnelles</h3>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <span class="text-muted d-block small">Nom et prénom</span>
                    <strong>{{ utilisateur.nom|upper }} {{ utilisateur.prenom }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <span class="text-muted d-block small">Adresse Email Professionnelle</span>
                    <strong>{{ utilisateur.email }}</strong>
                </div>
                <div class="col-md-6 mb-3">
                    <span class="text-muted d-block small">Numéro de téléphone</span>
                    <strong>{{ utilisateur.telephone ?? 'Non renseigné' }}</strong>
                </div>
            </div>
        </div>
        
    {% endif %}

</div>
    
{% endblock %}