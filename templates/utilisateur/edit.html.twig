{% extends 'base.html.twig' %}

{% block title %}Modifier le compte utilisateur{% endblock %}

{% block body %}
<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modifier le compte utilisateur</h1>
        
        {% if is_granted('ROLE_ADMIN') and app.user != utilisateur %}
            <a href="{{ path('app_utilisateur_index') }}" class="btn btn-secondary">Retour à la liste</a>
        {% else %}
            <a href="{{ path('app_utilisateur_profil') }}" class="btn btn-outline-dark">Retour à mon compte</a>
        {% endif %}
    </div>

    <div class="card p-4 shadow-sm mb-4 bg-white border-0">
        {{ include('utilisateur/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button type="submit" form="form-utilisateur" class="btn btn-dark">Mettre à jour mes informations</button>
        
        {% if is_granted('ROLE_ADMIN') and app.user != utilisateur %}
            <form method="post" action="{{ path('app_utilisateur_toggle', {'id': utilisateur.id}) }}" onsubmit="return confirm('Confirmer le changement de statut ?');">
                <button class="btn btn-sm btn-outline-danger">
                    {{ utilisateur.isVerified ? 'Désactiver le compte' : 'Réactiver le compte' }}
                </button>
            </form>
        {% endif %}
    </div>

</div>
{% endblock %}