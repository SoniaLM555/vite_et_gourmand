{% extends 'base.html.twig' %}

{% block title %}Détails de la commande{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Commande n°{{ commande.numeroCommande }}</h1>
        <a href="{{ path('app_commande_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Numéro</th>
                <th>Date de prestation</th>
                <th>Nb pers.</th>
                <th>Prix total</th>
                <th>Statut</th>
                <th>Matériel</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>{{ commande.id }}</td>
                <td>{{ commande.numeroCommande }}</td>
                <td>{{ commande.datePrestation ? commande.datePrestation|date('d/m/Y') : '' }}  à {{ commande.heureLivraison }}</td>
                <td>{{ commande.nombrePersonne }}</td>
                <td>{{ (commande.prixMenu + commande.prixLivraison) }} €</td>
                <td><span class="badge bg-secondary">{{ commande.statut }}</span></td>
                <td>
                    {% if commande.pretMateriel %}
                        <span class="text-success">Oui</span> ({{ commande.restitutionMateriel ? 'Rendu' : 'À récupérer' }})
                    {% else %}
                        <span class="text-muted">Non</span>
                    {% endif %}
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="/commande/{{ commande.id }}/edit" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    
    {% if commande.statut == 'Annulé' and commande.motifAnnulation is defined and commande.motifAnnulation is not empty %}
        <div class="card bg-light border-danger mt-4 shadow-sm">
            <div class="card-body">
                <h5 class="card-title text-danger fw-bold d-flex align-items-center gap-2 mb-2">
                    Motif d'annulation
                </h5>
                <p class="card-text text-dark mb-0"><strong>Motif saisi :</strong> {{ commande.motifAnnulation }}</p>
            </div>
        </div>
    {% endif %}

{% endblock %}
