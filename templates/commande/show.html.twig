{% extends 'base.html.twig' %}

{% block title %}Détails de la commande{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Commande n°{{ commande.numeroCommande }}</h1>
        <a href="{{ path('app_commande_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Numéro</th>
                <th>Date de prestation</th>
                <th>Nb pers.</th>
                <th>Prix total</th>
                <th>Statut</th>
                <th>Matériel</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>{{ commande.id }}</td>
                <td>{{ commande.numeroCommande }}</td>
                <td>{{ commande.datePrestation ? commande.datePrestation|date('d/m/Y') : '' }}  à {{ commande.heureLivraison }}</td>
                <td>{{ commande.nombrePersonne }}</td>
                <td>{{ (commande.prixMenu + commande.prixLivraison) }} €</td>
                <td><span class="badge bg-secondary">{{ commande.statut }}</span></td>
                <td>
                    {% if commande.pretMateriel %}
                        <span class="text-success">Oui</span> ({{ commande.restitutionMateriel ? 'Rendu' : 'À récupérer' }})
                    {% else %}
                        <span class="text-muted">Non</span>
                    {% endif %}
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        {{ include('commande/_delete_form.html.twig') }}
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    
{% endblock %}
