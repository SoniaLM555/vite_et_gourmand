{% extends 'base.html.twig' %}

{% block title %}Commande index{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des commandes</h1>
    </div>

    <div class="card p-3 mb-4 bg-light border-0 shadow-sm">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <label for="search-client" class="form-label small fw-bold text-secondary mb-1">Rechercher un client :</label>
                    <input type="text" id="search-client" class="form-control form-control-sm" placeholder="Saisissez un nom ou prénom...">
                </div>

                <div class="col-md-8">
                    <label class="form-label small fw-bold text-secondary mb-1">Filtrer par statut :</label>
                    <div class="d-flex gap-1 flex-wrap">
                        <button class="btn btn-sm btn-dark btn-filter active" data-status="tous">Tous</button>
                        <button class="btn btn-sm btn-outline-dark btn-filter" data-status="en attente">En attente</button>
                        <button class="btn btn-sm btn-outline-dark btn-filter" data-status="accepté">Accepté</button>
                        <button class="btn btn-sm btn-outline-dark btn-filter" data-status="en préparation">En préparation</button>
                        <button class="btn btn-sm btn-outline-dark btn-filter" data-status="livré">Livré</button>
                        <button class="btn btn-sm btn-outline-dark btn-filter" data-status="annulé">Annulé</button>
                    </div>
                </div>  
            </div>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>N° Commande</th>
                <th>Client</th>
                <th>Prestation</th>
                <th>Heure</th>
                <th>Prix menu</th>
                <th>Livraison</th>
                <th>Total</th>
                <th>Statut</th>
                <th>Matériel</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>

        {% for commande in commandes %}
            <tr class="commande-row" data-client="{{ commande.utilisateur.nom|lower }} {{ commande.utilisateur.prenom|lower }}" data-status="{{ commande.statut|lower }}">
                <td>{{ commande.id }}</td>
                <td>{{ commande.numeroCommande }}</td>
                <td><strong>{{ commande.utilisateur.nom|upper }} {{ commande.utilisateur.prenom }}</strong></td>
                <td>{{ commande.datePrestation }}</td>
                <td>{{ commande.heureLivraison }}</td>
                <td>{{ commande.prixMenu }} €</td>
                <td>
                    {% if commande.prixLivraison == 0 %}
                        <span class="text-success fw-bold">Gratuit (Bdx)</span>
                    {% else %}
                        {{ commande.prixLivraison }} €
                    {% endif %}
                </td>
                <td><strong>{{ (commande.prixMenu + commande.prixLivraison) }} €</strong></td>
                <td>
                    {% if commande.statut == 'En attente' %}
                        <span class="badge bg-warning text-dark">En attente</span>
                    {% elseif commande.statut == 'Accepté' %}
                        <span class="badge bg-success">Accepté</span>
                    {% else %}
                        <span class="badge bg-secondary">{{ commande.statut }}</span>
                    {% endif %}
                </td>
                <td>
                    {% if commande.pretMateriel %}
                        <span class="text-success">Oui</span> ({{ commande.restitutionMateriel ? 'Rendu ✅' : 'À récupérer ⏳' }})
                    {% else %}
                        <span class="text-muted">Non</span>
                    {% endif %}
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="/commande/{{ commande.id }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                        <a href="/commande/{{ commande.id }}/edit" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
               <td colspan="11" class="text-center text-muted py-3">Aucune commande n'a encore été enregistrée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-client');
    const filterButtons = document.querySelectorAll('.btn-filter');
    const rows = document.querySelectorAll('.commande-row');
    
    let currentStatus = 'tous';

    function filterTable() {
        const searchText = searchInput.value.toLowerCase().trim();

        rows.forEach(row => {
            const clientName = row.getAttribute('data-client');
            const rowStatus = row.getAttribute('data-status');
                const matchesSearch = clientName.includes(searchText);
                const matchesStatus = (currentStatus === 'tous' || rowStatus === currentStatus || (currentStatus === 'accepté' && rowStatus === 'accepté'));

                if (matchesSearch && matchesStatus) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

    searchInput.addEventListener('input', filterTable);

    filterButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            filterButtons.forEach(b => {
                b.classList.remove('active', 'btn-dark');
                b.classList.add('btn-outline-dark');
            });

                this.classList.remove('btn-outline-dark');
                this.classList.add('active', 'btn-dark');

                currentStatus = this.getAttribute('data-status');
                filterTable();
            });
        });
    });
</script>


{% endblock %}