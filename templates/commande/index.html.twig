{% extends 'base.html.twig' %}

{% block title %}Commande index{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des commandes</h1>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>N° Commande</th>
                <th>Client</th>
                <th>Prestation</th>
                <th>Heure</th>
                <th>Prix menu</th>
                <th>Livraison</th>
                <th>Total</th>
                <th>Statut</th>
                <th>Matériel</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>

        {% for commande in commandes %}
            <tr>
                <td>{{ commande.id }}</td>
                <td>{{ commande.numeroCommande }}</td>
                <td><strong>{{ commande.utilisateur.nom|upper }} {{ commande.utilisateur.prenom }}</strong></td>
                <td>{{ commande.datePrestation }}</td>
                <td>{{ commande.heureLivraison }}</td>
                <td>{{ commande.prixMenu }} €</td>
                <td>
                    {% if commande.prixLivraison == 0 %}
                        <span class="text-success fw-bold">Gratuit (Bdx)</span>
                    {% else %}
                        {{ commande.prixLivraison }} €
                    {% endif %}
                </td>
                <td><strong>{{ (commande.prixMenu + commande.prixLivraison) }} €</strong></td>
                <td>
                    {% if commande.statut == 'En attente' %}
                        <span class="badge bg-warning text-dark">En attente</span>
                    {% elseif commande.statut == 'Accepté' %}
                        <span class="badge bg-success">Accepté</span>
                    {% else %}
                        <span class="badge bg-secondary">{{ commande.statut }}</span>
                    {% endif %}
                </td>
                <td>
                    {% if commande.pretMateriel %}
                        <span class="text-success">Oui</span> ({{ commande.restitutionMateriel ? 'Rendu ✅' : 'À récupérer ⏳' }})
                    {% else %}
                        <span class="text-muted">Non</span>
                    {% endif %}
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_commande_show', {'id': commande.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                        <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier/Statut</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
               <td colspan="11" class="text-center text-muted py-3">Aucune commande n'a encore été enregistrée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}