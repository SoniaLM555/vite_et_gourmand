{% extends 'base.html.twig' %}

{% block title %}Commande index{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des commandes</h1>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>N° Commande</th>
                <th>Prestation</th>
                <th>Heure</th>
                <th>Prix menu</th>
                <th>Livraison</th>
                <th>Pers.</th>
                <th>Statut</th>
                <th>Matériel</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for commande in commandes %}
            <tr>
                <td>{{ commande.id }}</td>
                <td>{{ commande.numeroCommande }}</td>
                <td>{{ commande.datePrestation }}</td>
                <td>{{ commande.heureLivraison }}</td>
                <td>{{ commande.prixMenu }} €</td>
                <td>{{ commande.prixLivraison }} €</td>
                <td>{{ commande.nombrePersonne }}</td>
                <td><span class="badge bg-secondary">{{ commande.statut }}</span></td>
                <td>
                    {% if commande.pretMateriel %}
                        <span class="text-success">Oui</span>
                    {% else %}
                        <span class="text-muted">Non</span>
                    {% endif %}
                </td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_commande_show', {'id': commande.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                        <a href="{{ path('app_commande_edit', {'id': commande.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10" class="text-center">Aucun résultat trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_commande_new') }}" class="btn btn-sm btn-secondary">Ajouter une commande</a>

{% endblock %}