<form method="post" action="{{ path('app_commande_delete', {'id': commande.id}) }}" onsubmit="return confirm('Attention : Cette action est irréversible. Supprimer cette commande ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">
    <button class="btn btn-sm btn-outline-secondary">Supprimer la commande</button>
</form>
