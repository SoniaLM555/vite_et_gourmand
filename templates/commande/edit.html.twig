{% extends 'base.html.twig' %}

{% block title %}Modifier la commande{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modification de la commande n°{{ commande.numeroCommande }}</h1>
        {% if is_granted('ROLE_EMPLOYE') %}
            <a href="{{ path('app_commande_index') }}" class="btn btn-secondary">Retour à la liste</a>
        {% else %}
            <a href="{{ path('app_utilisateur_profil') }}" class="btn btn-secondary">Retour à mon espace</a>
        {% endif %}
    </div>
    
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show mb-4" role="alert">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card p-4 shadow-sm mb-4">   
        {{ form_start(form, {'attr': {'id': 'form-commande'}}) }}
    
    <div class="row">
        <div class="col-md-6 mb-3">
            {% if form.statut is defined %}
            {{ form_row(form.statut, {
                'label': 'Statut de la commande',
                'attr': {'class': 'form-select', 'id': 'select-statut'}
            }) }}
{% endif %}
        </div>
        
        {% if form.restitutionMateriel is defined %}
            {% if commande.pretMateriel %}
                <div class="col-md-6 mb-3" id="zone-restitution-materiel" style="display: none;">
                    {{ form_row(form.restitutionMateriel, {
                        'label': 'Matériel officiellement restitué ?',
                        'attr': {'id': 'check-restitution'}
                    }) }}
                </div>
            {% else %}
                {% do form.restitutionMateriel.setRendered() %}
            {% endif %}
        {% endif %}
    </div>

    {% if form.confirmation_contact is defined and form.motif_annulation is defined %}
        <div id="bloc-annulation" class="p-3 bg-light rounded border mb-3" style="display: none;">
            <h4 class="h6 text-danger fw-bold mb-3">Justificatif d'annulation obligatoire</h4>
            
            <div class="form-check mb-3">
                {{ form_widget(form.confirmation_contact, {'attr': {'class': 'form-check-input'}}) }}
                <label class="form-check-label small fw-bold text-dark" for="{{ form.confirmation_contact.vars.id }}">
                    Je confirme avoir contacté le client au préalable par appel GSM ou par e-mail.
                </label>
            </div>

            <div class="mb-3">
                <label for="{{ form.motif_annulation.vars.id }}" class="form-label small fw-bold text-secondary">Motif précis de l'annulation et mode de contact :</label>
                {{ form_widget(form.motif_annulation, {'attr': {'class': 'form-control form-control-sm', 'rows': '3', 'placeholder': 'Spécifiez la raison de l\'annulation et le mode de contact...'}}) }}
            </div>
        </div>
    {% endif %}

    <div class="col-12 mt-3 pt-3 border-top">
        {{ form_rest(form) }}
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button type="submit" class="btn btn-secondary">Mettre à jour</button>
    </div>

{{ form_end(form) }}
    </div>

<script>
function initialiserGestionStatuts() {
    const selectStatut = document.getElementById('select-statut') || document.querySelector('select[name="commande[statut]"]');
    if (!selectStatut) return;
    const blocAnnulation = document.getElementById('bloc-annulation');
    const zoneMateriel = document.getElementById('zone-restitution-materiel');
    
    const aDemandeMateriel = {{ commande.pretMateriel ? 'true' : 'false' }};

    for (let i = 0; i < selectStatut.options.length; i++) {
        const option = selectStatut.options[i];
        const valeur = option.value.toLowerCase();
        const texte = option.text.toLowerCase();

        if (valeur.includes('matériel') || valeur.includes('materiel') || texte.includes('matériel') || texte.includes('materiel')) {
            if (!aDemandeMateriel) {
                option.style.display = 'none'; 
                option.disabled = true;
            } else {
                option.style.display = 'block';
                option.disabled = false;
            }
        }
    }

    function gererChangementStatut() {
        const valeurSelectionnee = selectStatut.value;
        const texteSelectionne = selectStatut.options[selectStatut.selectedIndex] ? selectStatut.options[selectStatut.selectedIndex].text : '';

        if (valeurSelectionnee === 'Annulé' || texteSelectionne.toLowerCase().includes('annul')) {
            if (blocAnnulation) blocAnnulation.style.display = 'block';
        } else {
            if (blocAnnulation) {
                blocAnnulation.style.display = 'none';
                const checkContact = blocAnnulation.querySelector('input[type="checkbox"]');
                const motif = blocAnnulation.querySelector('textarea') || blocAnnulation.querySelector('input[type="text"]');
                if (checkContact) checkContact.checked = false;
                if (motif) motif.value = '';
            }
        }

        if (zoneMateriel && aDemandeMateriel) {
            const contientMotMateriel = valeurSelectionnee.toLowerCase().includes('matériel') 
                                      || valeurSelectionnee.toLowerCase().includes('materiel')
                                      || texteSelectionne.toLowerCase().includes('matériel')
                                      || texteSelectionne.toLowerCase().includes('materiel');

            if (contientMotMateriel) {
                zoneMateriel.style.display = 'block';
            } else {
                zoneMateriel.style.display = 'none';
                const checkRestit = document.getElementById('check-restitution') || zoneMateriel.querySelector('input[type="checkbox"]');
                if (checkRestit) checkRestit.checked = false;
            }
        }
    }

    selectStatut.removeEventListener('change', gererChangementStatut);
    selectStatut.removeEventListener('input', gererChangementStatut);
    selectStatut.addEventListener('change', gererChangementStatut);
    selectStatut.addEventListener('input', gererChangementStatut);

    gererChangementStatut();
}

document.addEventListener('DOMContentLoaded', initialiserGestionStatuts);
document.addEventListener('turbo:load', initialiserGestionStatuts);
document.addEventListener('turbo:render', initialiserGestionStatuts);
document.addEventListener('turbo:submit-end', function() {
    setTimeout(initialiserGestionStatuts, 50);
});
</script>
{% endblock %}