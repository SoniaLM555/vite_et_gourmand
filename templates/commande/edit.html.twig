{% extends 'base.html.twig' %}

{% block title %}Modifier la commande{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modification de la commande n°{{ commande.numeroCommande }}</h1>
        <a href="{{ path('app_commande_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
    
    <div class="card p-4 shadow-sm mb-4">   
        {{ include('commande/_form.html.twig') }}
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button type="submit" form="form-commande" class="btn btn-secondary">Mettre à jour</button>
        {{ include('commande/_delete_form.html.twig') }}
    </div>

{% endblock %}
