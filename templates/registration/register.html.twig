{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}

<div class="container py-5 d-flex justify-content-center">
    <div class="col-md-8 bg-charte-light p-5 rounded shadow-sm">
        
        <h1 class="h3 mb-4 font-weight-normal text-center">Créer un compte</h1>

       
        {% if form_errors(registrationForm) %}
            <div class="alert alert-danger">
                {{ form_errors(registrationForm) }}
            </div>
        {% endif %}

        {{ form_start(registrationForm) }}
            <div class="row">
                <div class="col-md-6">{{ form_row(registrationForm.nom) }}</div>
                <div class="col-md-6">{{ form_row(registrationForm.prenom) }}</div>
            </div>

            <div class="row">
                <div class="col-md-6">{{ form_row(registrationForm.email) }}</div>
                <div class="col-md-6">{{ form_row(registrationForm.telephone) }}</div>
            </div>

            <hr class="my-4">
            {{ form_row(registrationForm.adressePostale) }}
            <div class="row">
                <div class="col-md-6">{{ form_row(registrationForm.ville) }}</div>
                <div class="col-md-6">{{ form_row(registrationForm.pays) }}</div>
            </div>

            <hr class="my-4">

            {{ form_row(registrationForm.plainPassword, { label: 'Mot de passe' }) }}
            
            <div class="mt-3">
                {{ form_row(registrationForm.agreeTerms, { label: 'J\'accepte les conditions générales' }) }}
            </div>

            <button type="submit" class="btn btn-dark-custom w-100 mt-4">S'inscrire</button>
        {{ form_end(registrationForm) }}
    </div>
</div>

{% endblock %}