{% extends 'base.html.twig' %}

{% block title %}Modifier le menu{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-4">Modifier le menu : {{ menu.titre }}</h1>
        <a href="{{ path('app_menu_admin_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <div class="card p-4 shadow-sm mb-4">
        {{ include('menu/_form.html.twig') }}
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <button type="submit" form="form-menu" class="btn btn-secondary">Mettre à jour</button>
     
        {{ include('menu/_delete_form.html.twig') }}
    </div>
    
{% endblock %}
