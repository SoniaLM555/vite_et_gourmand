{% extends 'base.html.twig' %}
{% block title %}Menu - {{ menu.titre }}{% endblock %}

{% block body %}
<div class="container py-5 text-charte-dark">
    <div class="mb-4">
        <a href="{{ path('app_menu_index') }}" class="btn btn-link text-charte-dark mb-4">← Retour</a>
    </div>
    <div class="row align-items-center bg-charte-light p-4">
        <div class="col-md-6 text-center">
            <img src="{{ asset('images/' ~ (menu.imageName ?? 'default.jpg')) }}" class="img-fluid border">
        </div>
        <div class="col-md-6 ">
            <h1 class="fw-bold  mb-4">{{ menu.titre }}</h1>
            <p class="h3 mb-3">{{ menu.prixParPersonne }} €/personne</p>
            <p class="text-danger fw-bold mb-4">Plus que {{ menu.quantiteRestante }} commande(s) disponible(s)</p>
            <a href="#" class="btn btn-dark btn-lg px-4 py-2">Commander ce menu</a>
        </div>
    </div>

    <div class="py-5">
        <h2 class="fw-bold  mb-5 text-center">Contenu du menu</h2>
        <div class="row">
            {% set plats = {'Entrée': menu.entree, 'Plat principal': menu.platPrincipal, 'Dessert': menu.dessert} %}
            {% for nom, plat in plats %}
                <div class="col-md-4">
                    <p class=" fw-bold mb-3" style="color: var(--color-dark);">{{ nom }}</p>
                    <p class=" mb-1">{{ plat.nom ?? 'Non défini' }}</p>
                    {# Allergènes non centrés #}
                    <p class="small text-muted">Allergènes: {% for a in plat.allergenes %}{{ a.nom }}{% if not loop.last %}, {% endif %}{% else %}Aucun{% endfor %}</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="row pt-5">
        {# Caractéristiques (1/3) - Titre gras, reste noir #}
        <div class="col-md-4 mb-3">
            <div class="p-3 bg-charte-light  h-100">
                <p class="fw-bold text-uppercase mb-3 text-center">Caractéristiques</p>
                <p class="mb-1 text-custom-dark">• Thème : {% for t in menu.theme %}{{ t.nom }}{% if not loop.last %}, {% endif %}{% endfor %}</p>
                <p class="mb-1 text-custom-dark">• Régime : {% for r in menu.regimes %}{{ r.nom }}{% if not loop.last %}, {% endif %}{% endfor %}</p>
                <p class="mb-1 ">• Stock : {% if menu.quantiteRestante > 0 %} {{ menu.quantiteRestante }}  {{ menu.quantiteRestante == 1 ? 'restant' : 'restants' }}{% else %} Épuisé
                                        {% endif %}</p>
            </div>
        </div>
        {# Conditions importantes (2/3) - Titre gras, reste noir #}
        <div class="col-md-8 mb-3 fw-bold">
            <div class="p-3 bg-charte-light h-100 ">
                <p class="fw-bold text-uppercase mb-3 text-center">Conditions importantes</p>
                <p class="mb-1 text-custom-dark">• Délai : {{ menu.delai ?? 'Non précisé' }}</p>
                <p class="mb-1 text-custom-dark">• Stockage : {{ menu.stockage ?? 'Non précisé' }}</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}