{% extends 'base.html.twig' %}

{% block title %}Gestion des menus{% endblock %}

{% block body %}
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Gestion des menus</h1>
        <a href="{{ path('app_menu_new') }}"  class="btn btn-sm btn-secondary">Ajouter un menu</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Prix</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for menu in menus %}
            <tr>
                <td>{{ menu.id }}</td>
                <td>{{ menu.titre }}</td>
                <td>{{ menu.prixParPersonne }} €</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_menu_show', {'id': menu.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                        <a href="{{ path('app_menu_edit', {'id': menu.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucun résultat trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    
{% endblock %}