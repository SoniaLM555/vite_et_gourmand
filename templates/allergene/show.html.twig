{% extends 'base.html.twig' %}

{% block title %}Détails de l'allergène{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Détails de l'allergène : {{ allergene.nom }}</h1>
        <a href="{{ path('app_allergene_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>{{ allergene.id }}</td>
                <td>{{ allergene.nom }}</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_allergene_edit', {'id': allergene.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        {{ include('allergene/_delete_form.html.twig') }}
                    </div>
                </td>
            </tr>
        </tbody>
    </table>


{% endblock %}
