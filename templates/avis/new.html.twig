{% extends 'base.html.twig' %}

{% block title %}Nouvel avis{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Ajouter un nouvel avis</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_avis_index') }}" class="btn btn-secondary">Retour à la liste</a>
        {% else %}
            <a href="{{ path('app_utilisateur_profil') }}" class="btn btn-secondary">Retour</a>
        {% endif %}
    </div>

    <div class="card p-4 shadow-sm mb-4">
        {{ include('avis/_form.html.twig') }}
    </div>

    <div class="d-flex justify-content-start mt-3">
        <button type="submit" form="form-avis" class="btn btn-secondary">Enregistrer l'avis</button>
    </div> 

{% endblock %}
