{% extends 'base.html.twig' %}

{% block title %}Détails de l'avis{% endblock %}

{% block body %}
    <h1>Détails de l'avis</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th><td>{{ avi.id }}</td>
            </tr>
            <tr>
                <th>Commentaire</th><td>{{ avi.commentaire }}</td>
            </tr>
            <tr>
                <th>Note</th><td>{{ avi.note }}</td>
            </tr>
            <tr>
                <th>Statut</th><td>{{ avi.statut }}</td>
            </tr>
            <tr>
                <th>Date de publication</th><td>{{ avi.datePublication ? avi.datePublication|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_avis_index') }}">Retour à la liste</a>

    <a href="{{ path('app_avis_edit', {'id': avi.id}) }}">Modifier</a>

    {{ include('avis/_delete_form.html.twig') }}
{% endblock %}
