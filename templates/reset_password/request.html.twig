{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe{% endblock %}

{% block body %}
<div class="container py-5 d-flex justify-content-center">
    <div class="col-md-6 bg-charte-light p-5 rounded shadow-sm">
        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}
        
        <h1 class="h3 mb-3 font-weight-normal text-center">Mot de passe oublié</h1>

        {{ form_start(requestForm) }}
            <div class="mb-3">
                {{ form_label(requestForm.email, 'Votre adresse e-mail', {'label_attr': {'class': 'form-label fw-bold text-dark'}}) }}
                {{ form_widget(requestForm.email, {'attr': {'class': 'form-control', 'placeholder': 'adresse@exemple.com'}}) }}
                {{ form_errors(requestForm.email) }}
            </div>
            
            <div class="mb-4">
                <small class="text-muted">
                    Saisissez l'adresse e-mail associée à votre compte. Nous vous enverrons immédiatement un lien sécurisé pour créer votre nouveau mot de passe.
                </small>
            </div>

            <button class="btn btn-dark w-100">Envoyer le lien de réinitialisation</button>
        {{ form_end(requestForm) }}
    </div>
</div>
{% endblock %}