{% extends 'base.html.twig' %}

{% block title %}Détails du thème{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Détails du thème : {{ theme.nom }}</h1>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à l'accueil</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom du thème</th>
                <th>Actions</th>
            </tr>
        </thead>
        
        <tbody>
            <tr>
                <td>{{ theme.id }}</td>
                <td>{{ theme.nom }}</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_theme_edit', {'id': theme.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
                        {{ include('theme/_delete_form.html.twig') }}
                    </div>
                </td>
            </tr>
        </tbody>
    </table>

    <div class="mt-4">
        <a href="{{ path('app_theme_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
    
{% endblock %}
