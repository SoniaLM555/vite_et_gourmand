<form method="post" action="{{ path('app_theme_delete', {'id': theme.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce thème ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ theme.id) }}">
    <button class="btn btn-sm btn-outline-secondary">Supprimer le thème</button>
</form>
