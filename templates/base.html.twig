    <!DOCTYPE html>
    <html>
        <head>
            <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>{% block title %}Vite et Gourmand{% endblock %}</title><link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🍴</text></svg>">
            
            {% block stylesheets %}
            {% endblock %}

            {% block javascripts %}
                {% block importmap %}{{ importmap('app') }}{% endblock %}
            {% endblock %}
            <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
            
            <style>
                
                :root {
                    --font-main: 'Montserrat', sans-serif;
                    --font-title: 'Playfair Display', serif;
                    --color-light: #E5E5E5;
                    --color-dark: #606060;  
                    --color-text: #333333; 
                }

                body {
                    font-family: var(--font-main);
                    color: #333333;
                    background-color: #FEFEFE;
                    line-height: 1.6;
                }

            
                h1, h2, h3, h4, h5, h6, .navbar-brand {
                    font-family: var(--font-title);
                    font-weight: 700;
                }

                .bg-charte-light { 
                    background-color: var(--color-light) !important; 
                }

                .text-charte-dark { 
                    color: var(--color-text) !important; 
                }

                .border-charte-dark { 
                    border-color: var(--color-dark) !important;
                }

                .btn-charte { 
                    background-color: var(--color-dark); 
                    color: #fff; border-radius: 6px;
                }

                .btn-charte:hover { 
                    background-color: #4a4a4a; 
                    color: #fff; 
                }

                .btn-dark-custom {
                    background-color: #1A1A1A;
                    color: #FEFEFE;
                    transition: all 0.3s ease;
                    font-family: var(--font-main);
                    font-size: 0.9rem;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                }

                
                .footer-title {
                    font-family: var(--font-main) !important; 
                    font-size: 0.7rem;
                    letter-spacing: 2px;
                    text-transform: uppercase;
                }

                .footer-text {
                    font-family: var(--font-main);
                    /* Un chouïa plus petit pour être sûr que ça rentre dans les 5 colonnes */
                    font-size: clamp(0.6rem, 1.2vw, 0.75rem); 
                }

                .footer-logo {
                    font-family: var(--font-title);
                    /* On s'assure que le minimum est assez petit pour mobile (1rem) */
                    font-size: clamp(1rem, 2.5vw, 1.8rem); 
                    font-weight: 700;
                    margin: 0;
                    white-space: nowrap;
                }

                .footer-link {
                    font-family: var(--font-main);
                    font-size: 0.65rem; 
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    color: #6c757d !important; 
                    text-decoration: none;
                }

                .horaires-container {
                    max-width: 220px; 
                }

                .pagination .page-link {
                    color: #1A1A1A;
                    background-color: transparent;
                    transition: all 0.3s;
                }

                .pagination .page-item.active .page-link {
                    background-color: #1A1A1A;
                    border-color: #1A1A1A;
                    color: #FEFEFE;
                }

                .pagination .page-link:hover {
                    background-color: #f8f9fa;
                    color: #000;
                }

                
                .btn-outline-secondary.input-filter {
                    border: 1px solid #606060 !important;
                    color: #606060 !important;
                    background-color: transparent !important;
                    border-radius: 6px !important;
                    text-align: left; /* Aligne le texte à gauche comme un select */
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                }

                .btn-outline-secondary.input-filter:hover {
                    background-color: #f8f9fa !important;
                    color: #606060 !important;
                }

                .dropdown-menu {
                    border: 1px solid #606060 !important;
                    border-radius: 6px !important;
                }
                
                
                .pagination .page-item:first-child .page-link { font-size: 0; }
                .pagination .page-item:first-child .page-link::before { content: "«"; font-size: 1rem; }

                .pagination .page-item:last-child .page-link { font-size: 0; }
                .pagination .page-item:last-child .page-link::after { content: "»"; font-size: 1rem; }  

                
                .pagination {
                    margin-top: 2rem;
                    gap: 8px; 
                }

                
                .pagination .page-item .page-link {
                    width: 45px; 
                    height: 45px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    border-radius: 8px; /* Coins arrondis */
                    border: 1px solid #dee2e6;
                    color: #1A1A1A;
                    font-family: var(--font-main);
                    font-weight: 600;
                    transition: all 0.3s ease;
                }

                
                .pagination .page-item .page-link:hover {
                    background-color: #1A1A1A;
                    color: #FFFFFF;
                    border-color: #1A1A1A;
                }

                
                .pagination .page-item.active .page-link {
                    background-color: #1A1A1A;
                    border-color: #1A1A1A;
                    color: #FFFFFF;
                }

                
                .pagination .page-item.disabled .page-link {
                    background-color: #f8f9fa;
                    color: #ccc;
                    border-color: #dee2e6;
                }     

            </style>

        </head>
        <body>

            <nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top" data-turbo="false">
                <div class="container">
                    <a class="navbar-brand" href="{{ path('app_home') }}">Vite & Gourmand</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto align-items-center">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active fw-bold{% endif %}" href="{{ path('app_home') }}">Accueil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_menu_index' %}active fw-bold{% endif %}" href="{{ path('app_menu_index') }}">Menus</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_contact' %}active fw-bold{% endif %}" href="{{ path('app_contact') }}">Contact</a>
                            </li>

                            {% if is_granted('ROLE_ADMIN') %}
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-danger fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                                        Administration
                                    </a>
                                    <ul class="dropdown-menu">
                                        {# Section Carte #}
                                        <li><h6 class="dropdown-header">Gestion Carte</h6></li>
                                        <li><a class="dropdown-item" href="{{ path('app_plat_index') }}">Plats</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_menu_admin_index') }}">Menus</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_allergene_index') }}">Allergènes</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_regime_index') }}">Régimes</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_theme_index') }}">Thèmes</a></li>
                                        
                                        <li><hr class="dropdown-divider"></li>
                                        
                                        {# Section Client #}
                                        <li><h6 class="dropdown-header">Espace Client</h6></li>
                                        <li><a class="dropdown-item" href="{{ path('app_utilisateur_index') }}">Utilisateurs</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_commande_index') }}">Commandes</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_avis_index') }}">Avis</a></li>
                                        
                                        <li><hr class="dropdown-divider"></li>
                                        
                                        {# Section Config #}
                                        <li><h6 class="dropdown-header">Configuration</h6></li>
                                        <li><a class="dropdown-item" href="{{ path('app_horaire_index') }}">Horaires</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_role_index') }}">Rôles</a></li>
                                    </ul>
                                </li>
                            {% endif %}

                            <li class="nav-item ms-lg-3">
                                {% if app.user %}
                                    <div class="d-flex align-items-center gap-3">
                                        <a href="{{ path('app_utilisateur_profil') }}" class="text-dark fw-bold text-decoration-none small me-2">👤 {{ app.user.prenom }} {{ app.user.nom }}</a>
                                        
                                        <a class="nav-link fw-bold text-dark" href="{{ path('app_commande_panier') }}">
                                            🛒 Mon Panier 
                                            {% if app.session.get('panier')|length > 0 %}
                                                <span class="badge bg-danger">{{ app.session.get('panier')|length }}</span>
                                            {% endif %}
                                        </a>
                                        
                                        <a class="nav-link" href="{{ path('app_logout') }}" style="background-color: #A00; color: #ffffff; padding: 0.5rem 1rem; border-radius: 4px;">Déconnexion</a>
                                    </div>
                                {% else %}
                                    <div class="d-flex gap-2">
                                        <a class="nav-link" href="{{ path('app_login') }}" style="background-color: #000000; color: #ffffff; padding: 0.5rem 1rem; border-radius: 4px;">Connexion</a>
                                        <a class="nav-link" href="{{ path('app_register') }}" style="background-color: #606060; color: #ffffff; padding: 0.5rem 1rem; border-radius: 4px;">Inscription</a>
                                    </div>
                                {% endif %}
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <div class="container mt-4">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            <main class="container-lg my-4">
            
                {% block body %}{% endblock %}
            </main>

            <footer class="bg-dark text-white py-5 mt-5">
                <div class="container">
                    
                    <div class="row align-items-center justify-content-around mb-5 g-0">
                        
                        <div class="col-5 col-md-4 d-flex justify-content-center p-0">
                            {{ render(controller('App\\Controller\\HoraireController::footerList')) }}
                        </div>

                        <div class="col-6 col-md-4 d-flex justify-content-center p-0">
                            <div class="bg-light text-dark py-3 px-3 shadow-sm" style="width: fit-content; max-width: 100%; border-radius: 2px;">
                                <h2 class="footer-logo text-center mb-0">Vite & Gourmand</h2>
                            </div>
                        </div>
                    </div>
                
                    <div class="row pt-4">
                        <div class="col-12 text-center">
                            <div class="d-flex flex-column flex-md-row justify-content-center align-items-center gap-3 gap-md-5">
                            <a href="{{ path('app_mentions_legales') }}" class="footer-link">Mentions Légales</a>
                            <a href="{{ path('app_cgv') }}" class="footer-link">Conditions générales de vente</a>
                        </div>
                        </div>
                    </div> 
                </div>
            </footer>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        </body>
    </html>
